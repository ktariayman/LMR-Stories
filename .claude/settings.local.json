{
  "permissions": {
    "allow": [
      "Bash(npx create-expo-app:*)",
      "Bash(npx create-expo-app@latest . --template blank-typescript --overwrite)",
      "Bash(npx create-expo-app@latest temp_expo --template blank-typescript)",
      "Bash(cp -r temp_expo/assets .)",
      "Bash(cp temp_expo/index.ts .)",
      "Bash(cp temp_expo/package.json .)",
      "Bash(cp temp_expo/package-lock.json .)",
      "Bash(cp temp_expo/tsconfig.json .)",
      "Bash(cp temp_expo/app.json .)",
      "Bash(cp temp_expo/App.tsx .)",
      "Bash(cp -r temp_expo/node_modules .)",
      "Bash(npx expo:*)",
      "Bash(npm install:*)",
      "Bash(powershell.exe -Command \"Get-NetTCPConnection -LocalPort 8081 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; Write-Host ''Done''\")"
    ]
  }
}

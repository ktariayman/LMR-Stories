PORT=3001

# PostgreSQL
DATABASE_URL=postgres://lmr:lmr_password@localhost:5432/lmr_stories

# Redis
REDIS_URL=redis://localhost:6379

# REQUIRED: JWT secret for authentication (use a long random string)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-characters

# AI providers (at least one required for story generation)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: local Ollama URL for AI fallback
# OLLAMA_URL=http://localhost:11434

# Optional: Google Cloud TTS for high-quality audio
# GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# Optional: restrict CORS origins (comma-separated). Leave empty to allow all (dev only)
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006
